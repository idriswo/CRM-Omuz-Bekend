generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id       Int       @id @default(autoincrement())
  title    String
  city     String
  district String
  address  String
  students  Student[]
  groups    Group[]
  employees Employee[]
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  duration    String
  price       Int
  leads       Lead[]
  groups      Group[]
}

model Student {
  id            Int           @id @default(autoincrement())
  first_name    String
  last_name     String
  birth_date    DateTime
  gender        String
  address       String?
  email         String?
  phone         String
  father_phone  String?
  photo         String?
  status        String        @default("active") // active|inactive|finished
  branch_id     Int?
  branch        Branch?       @relation(fields: [branch_id], references: [id])
  groups        Group[]       @relation("StudentGroups")
  contracts       Contract[]
  graduate_info   GraduateInfo?
  journal_entries JournalEntry[]
  created_at      DateTime       @default(now())
}

model Contract {
  id         Int      @id @default(autoincrement())
  student_id Int
  student    Student  @relation(fields: [student_id], references: [id])
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())
}

// Тибқи ишораи TZ: "дар як ҷадвали алоҳидаи GraduateInfo (ё майдонҳои иловагӣ дар Student)"
model GraduateInfo {
  id              Int     @id @default(autoincrement())
  student_id      Int     @unique
  student         Student @relation(fields: [student_id], references: [id])
  work_place      String?
  has_certificate Boolean @default(false)
  tag             String?
}

model Group {
  id                Int           @id @default(autoincrement())
  name              String
  course_id         Int
  course            Course        @relation(fields: [course_id], references: [id])
  start_date        DateTime
  end_date          DateTime
  duration          String
  required_students Int
  branch_id         Int
  branch            Branch        @relation(fields: [branch_id], references: [id])
  status            String        @default("active")
  tag               String?
  students          Student[]     @relation("StudentGroups")
  weeks             JournalWeek[]
  created_at        DateTime      @default(now())
}

model JournalWeek {
  id          Int            @id @default(autoincrement())
  group_id    Int
  group       Group          @relation(fields: [group_id], references: [id])
  week_number Int
  dates       DateTime[]
  entries     JournalEntry[]
}

model JournalEntry {
  id         Int         @id @default(autoincrement())
  week_id    Int
  week       JournalWeek @relation(fields: [week_id], references: [id])
  student_id Int
  student    Student     @relation(fields: [student_id], references: [id])
  day_date   DateTime
  attendance Boolean
  score      Int?
  bonus      Int?
  exam       Int?

  @@unique([week_id, student_id, day_date])
}

model Lead {
  id          Int      @id @default(autoincrement())
  full_name   String
  phone       String
  lesson_time String?
  course_id   Int?
  course      Course?  @relation(fields: [course_id], references: [id])
  utm_source  String?
  occupation  String?
  notes       String?
  type        String   @default("Lead") // Lead|Client
  coupons     Coupon[]
  created_at  DateTime @default(now())
}

model Coupon {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  discount   Int // фоиз ё маблағи тахфиф
  lead_id    Int?
  lead       Lead?    @relation(fields: [lead_id], references: [id])
  created_at DateTime @default(now())
}

model Employee {
  id          Int           @id @default(autoincrement())
  first_name  String
  last_name   String
  position    String
  experience  Int?
  branch_id   Int?
  branch      Branch?       @relation(fields: [branch_id], references: [id])
  phone       String
  email       String?
  mentor_level MentorLevel?
  created_at  DateTime      @default(now())
}

model MentorLevel {
  id          Int      @id @default(autoincrement())
  employee_id Int      @unique
  employee    Employee @relation(fields: [employee_id], references: [id])
  level       String
}

model User {
  id            Int      @id @default(autoincrement())
  phone         String   @unique
  password      String
  full_name     String
  role_id       Int?
  branch_id     Int?
  refresh_token String?
  created_at    DateTime @default(now())
}
