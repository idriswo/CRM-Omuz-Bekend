generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id       Int       @id @default(autoincrement())
  title    String
  city     String
  district String
  address  String
  students  Student[]
  groups    Group[]
  employees Employee[]
  payments  Payment[]
  salaries  Salary[]
  avans     Avans[]
}

model Course {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  duration    String
  price       Int
  leads       Lead[]
  groups      Group[]
}

model Student {
  id            Int           @id @default(autoincrement())
  first_name    String
  last_name     String
  birth_date    DateTime
  gender        String
  address       String?
  email         String?
  phone         String
  father_phone  String?
  photo         String?
  status        String        @default("active") // active|inactive|finished
  left_at       DateTime? // вақте status ба inactive иваз мешавад, ин пур мешавад (барои left-courses chart)
  left_reason   String? // сабаби тарки курс (сутуни Reason дар Left courses)
  telegram_username String?
  description       String?
  is_top            Boolean @default(false) // тоҷи 👑 дар рӯйхати донишҷӯён
  phones            Json? // [{ label: "Father", number: "93 435 4943" }]
  branch_id     Int?
  branch        Branch?       @relation(fields: [branch_id], references: [id])
  groups        Group[]       @relation("StudentGroups")
  contracts       Contract[]
  graduate_info   GraduateInfo?
  journal_entries JournalEntry[]
  payments        Payment[]
  debtors         Debtor[]
  user            User? // login-и донишҷӯ (агар superadmin/admin барояш сохта бошад)
  coin_balance      Int                @default(0)
  coin_transactions CoinTransaction[]
  created_at        DateTime           @default(now())
}

// Ledger-и coin: ҳам бонуси худкори ҳафтагӣ, ҳам иловаи дастӣ, ҳам харҷ (spend)
model CoinTransaction {
  id         Int      @id @default(autoincrement())
  student_id Int
  student    Student  @relation(fields: [student_id], references: [id])
  amount     Int // + барои earn, - барои spend
  type       String // auto_weekly | manual | spend
  reason     String?
  created_by Int? // user_id-и админе, ки илова/харҷ кардааст (барои manual/spend)
  created_at DateTime @default(now())
}

model Contract {
  id         Int      @id @default(autoincrement())
  student_id Int
  student    Student  @relation(fields: [student_id], references: [id])
  start_date DateTime
  end_date   DateTime
  created_at DateTime @default(now())
}

// Тибқи ишораи TZ: "дар як ҷадвали алоҳидаи GraduateInfo (ё майдонҳои иловагӣ дар Student)"
model GraduateInfo {
  id              Int     @id @default(autoincrement())
  student_id      Int     @unique
  student         Student @relation(fields: [student_id], references: [id])
  work_place      String?
  has_certificate Boolean @default(false)
  tag             String?
}

model Group {
  id                Int           @id @default(autoincrement())
  name              String
  course_id         Int
  course            Course        @relation(fields: [course_id], references: [id])
  start_date        DateTime
  end_date          DateTime
  duration          String
  required_students Int
  branch_id         Int
  branch            Branch        @relation(fields: [branch_id], references: [id])
  status            String        @default("active")
  tag               String?
  capacity          Int? // ҳадди ниҳоии ҷойҳо (Passing students X/Y)
  description       String?
  duration_type     String? // month|year
  format            String? // online|offline
  telegram_link     String?
  sheet_url         String? // линки Google Sheets, ки дар табақаи журнал нишон дода мешавад
  sheet_id          String? // id-и ҳамон ҳуҷҷат — барои навиштани журнал ба он
  mentors           Employee[]       @relation("GroupMentors")
  students          Student[]        @relation("StudentGroups")
  schedule_slots    GroupScheduleSlot[]
  weeks             JournalWeek[]
  timetable_entries TimetableEntry[]
  payments          Payment[]
  created_at        DateTime         @default(now())
}

// Ҷадвали ҳафтагии гурӯҳ (Schedule sheet) — сода: рӯзи ҳафта + вақти сар/анҷом
model GroupScheduleSlot {
  id       Int    @id @default(autoincrement())
  group_id Int
  group    Group  @relation(fields: [group_id], references: [id], onDelete: Cascade)
  weekday  String // Mn|Tu|Wd|Th|Fr|Sa|Su
  start    String // "18:00"
  end      String // "20:00"
}

model JournalWeek {
  id          Int            @id @default(autoincrement())
  group_id    Int
  group       Group          @relation(fields: [group_id], references: [id])
  week_number Int
  dates       DateTime[]
  entries     JournalEntry[]
}

model JournalEntry {
  id         Int         @id @default(autoincrement())
  week_id    Int
  week       JournalWeek @relation(fields: [week_id], references: [id])
  student_id Int
  student    Student     @relation(fields: [student_id], references: [id])
  day_date   DateTime
  attendance Boolean
  score      Int?
  bonus      Int?
  exam       Int?
  comment    String?
  late       Int? // дақиқаи дер мондан

  @@unique([week_id, student_id, day_date])
}

model Lead {
  id          Int      @id @default(autoincrement())
  full_name   String
  phone       String
  lesson_time String?
  course_id   Int?
  course      Course?  @relation(fields: [course_id], references: [id])
  utm_source  String?
  occupation  String?
  notes       String?
  type        String   @default("Lead") // Lead|Client
  coupons     Coupon[]
  created_at  DateTime @default(now())
}

model Coupon {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  discount   Int // фоиз ё маблағи тахфиф
  lead_id    Int?
  lead       Lead?    @relation(fields: [lead_id], references: [id])
  created_at DateTime @default(now())
}

model Employee {
  id          Int           @id @default(autoincrement())
  first_name  String
  last_name   String
  position    String
  experience  Int?
  branch_id   Int?
  branch      Branch?       @relation(fields: [branch_id], references: [id])
  phone       String
  email       String?
  mentor_level      MentorLevel?
  mentor_groups     Group[]       @relation("GroupMentors")
  timetable_entries TimetableEntry[]
  salaries          Salary[]
  avans             Avans[]
  created_at        DateTime         @default(now())
}

model MentorLevel {
  id          Int      @id @default(autoincrement())
  employee_id Int      @unique
  employee    Employee @relation(fields: [employee_id], references: [id])
  level       String
}

model TimetableEntry {
  id          Int      @id @default(autoincrement())
  course_name String
  group_id    Int?
  group       Group?   @relation(fields: [group_id], references: [id])
  type        String // Lecture
  start_time  DateTime
  end_time    DateTime
  class_room  String
  mentor_id   Int
  mentor      Employee @relation(fields: [mentor_id], references: [id])
  date        DateTime
  repeat_days Int[] // 0=Якшанбе...6=Шанбе, барои такрори ҳафтагӣ
}

model Payment {
  id         Int      @id @default(autoincrement())
  student_id Int
  student    Student  @relation(fields: [student_id], references: [id])
  amount     Int
  discount   Int      @default(0)
  paid       Int
  date       DateTime
  group_id   Int?
  group      Group?   @relation(fields: [group_id], references: [id])
  branch_id  Int?
  branch     Branch?  @relation(fields: [branch_id], references: [id])
  status     String // active|prepayment
}

model Budget {
  id               Int      @id @default(autoincrement())
  category_name    String
  from_date        DateTime
  to_date          DateTime
  amount_allocated Int
  amount_spent     Int      @default(0)
  status           String
}

model Salary {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id])
  amount      Int
  date        DateTime
  branch_id   Int
  branch      Branch   @relation(fields: [branch_id], references: [id])
}

model Avans {
  id          Int      @id @default(autoincrement())
  employee_id Int
  employee    Employee @relation(fields: [employee_id], references: [id])
  amount      Int
  date        DateTime
  branch_id   Int
  branch      Branch   @relation(fields: [branch_id], references: [id])
}

model Debtor {
  id                Int      @id @default(autoincrement())
  student_id        Int
  student           Student  @relation(fields: [student_id], references: [id])
  from_date         DateTime
  to_date           DateTime
  total_debt_amount Int
  payment_per_month Int
  total_paid_amount Int      @default(0)
  notes             String?
  status            String // inprogress|paid — худкор ҳисоб карда мешавад
}

model Expense {
  id     Int      @id @default(autoincrement())
  title  String
  amount Int
  date   DateTime
}

model SmsTemplate {
  id          Int    @id @default(autoincrement())
  title       String
  description String
}

model SmsHistory {
  id      Int      @id @default(autoincrement())
  title   String
  sent_at DateTime @default(now())
}

model User {
  id                Int      @id @default(autoincrement())
  phone             String   @unique
  password          String
  full_name         String
  role_id           Int?
  role              Role?    @relation(fields: [role_id], references: [id])
  branch_id         Int?
  // Агар role=student бошад, ин ба профили Student пайваст мешавад
  student_id        Int?     @unique
  student           Student? @relation(fields: [student_id], references: [id])
  // Танҳо барои role=admin маъно дорад: superadmin/director метавонанд ин имконро хомӯш/фаъол кунанд
  can_add_students  Boolean  @default(true)
  refresh_token     String?
  reset_code        String?
  reset_code_expires DateTime?
  logs              Log[]
  notifications     Notification[]
  created_at        DateTime @default(now())
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  title      String
  message    String
  read       Boolean  @default(false)
  created_at DateTime @default(now())
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String
  permissions Permission[]
  users       User[]
}

model Permission {
  id      Int     @id @default(autoincrement())
  name    String
  group   String // барои филтри "filter"
  role_id Int?
  role    Role?   @relation(fields: [role_id], references: [id])
  enabled Boolean @default(true)
}

model Log {
  id      Int      @id @default(autoincrement())
  user_id Int
  user    User     @relation(fields: [user_id], references: [id])
  action  String
  entity  String
  date    DateTime @default(now())
}
